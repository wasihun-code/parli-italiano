{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@app/utils/analytics": ["src/lib/analytics.ts"],
      "@app/navigation/AppNavigator": ["src/lib/AppNavigator.d.ts"],
      "@app/*": ["src/*"],
      "@shared/store/*": ["src/store/*"],
      "@shared/utils/*": ["src/utils/*"],
      "@shared/data/*": ["src/data/*"],
      "@shared/ai/*": ["src/ai/*"],
      "@shared/theme/*": ["src/theme/*"],
      "zustand": ["./node_modules/zustand"],
      "zustand/*": ["./node_modules/zustand/*"]
    },
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": false,
    "strict": false,
    "noImplicitAny": false
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts", "src/**/*.spec.ts"]
}
