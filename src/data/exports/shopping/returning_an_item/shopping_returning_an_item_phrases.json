[
  {"id": "s49-p1", "choicesItalian": ["Vorrei restituire questo.", "Voglio comprare questo.", "Cerco un regalo.", "Dov'è l'uscita?"], "choicesEnglish": ["I'd like to return this.", "I want to buy this.", "I'm looking for a gift.", "Where is the exit?"], "correctAnswerItalian": "Vorrei restituire questo.", "correctAnswerEnglish": "I'd like to return this.", "feedback": {"correctItalian": "Esatto! Frase chiave per il reso.", "incorrectItalian": "No, vuole restituire l'oggetto.", "correctEnglish": "Exactly! Key phrase for the return.", "incorrectEnglish": "No, he wants to return the item."}},
  {"id": "s49-p2", "choicesItalian": ["C'è un problema.", "Va tutto bene.", "È molto bello.", "Costa poco."], "choicesEnglish": ["There's a problem.", "Everything is fine.", "It's very beautiful.", "It costs little."], "correctAnswerItalian": "C'è un problema.", "correctAnswerEnglish": "There's a problem.", "feedback": {"correctItalian": "Bene! Per introdurre il difetto.", "incorrectItalian": "No, c'è un problema.", "correctEnglish": "Good! To introduce the defect.", "incorrectEnglish": "No, there's a problem."}},
  {"id": "s49-p3", "choicesItalian": ["È difettoso.", "È nuovo di zecca.", "È un classico.", "È in offerta."], "choicesEnglish": ["It's defective.", "It's brand new.", "It's a classic.", "It's on sale."], "correctAnswerItalian": "È difettoso.", "correctAnswerEnglish": "It's defective.", "feedback": {"correctItalian": "Ottimo! Spiega perché lo restituisce.", "incorrectItalian": "No, ha un difetto.", "correctEnglish": "Great! Explains why he's returning it.", "incorrectEnglish": "No, it has a defect."}},
  {"id": "s49-p4", "choicesItalian": ["C'è un buco sulla manica.", "Il colore è sbagliato.", "La taglia è piccola.", "Il prezzo è alto."], "choicesEnglish": ["There's a hole on the sleeve.", "The color is wrong.", "The size is small.", "The price is high."], "correctAnswerItalian": "C'è un buco sulla manica.", "correctAnswerEnglish": "There's a hole on the sleeve.", "feedback": {"correctItalian": "Bene! Specifica il danno.", "incorrectItalian": "No, parla del buco.", "correctEnglish": "Good! Specifies the damage.", "incorrectEnglish": "No, it mentions the hole."}},
  {"id": "s49-p5", "choicesItalian": ["Ha lo scontrino?", "Ha una borsa?", "Ha dei soldi?", "Ha fame?"], "choicesEnglish": ["Do you have the receipt?", "Do you have a bag?", "Do you have money?", "Are you hungry?"], "correctAnswerItalian": "Ha lo scontrino?", "correctAnswerEnglish": "Do you have the receipt?", "feedback": {"correctItalian": "Esatto! Domanda tipica del commesso.", "incorrectItalian": "No, chiede dello scontrino.", "correctEnglish": "Exactly! Typical clerk question.", "incorrectEnglish": "No, he's asking for the receipt."}},
  {"id": "s49-p6", "choicesItalian": ["Sì, eccolo qui.", "No, l'ho perso.", "Forse l'ho a casa.", "Non lo so."], "choicesEnglish": ["Yes, here it is.", "No, I lost it.", "Maybe I have it at home.", "I don't know."], "correctAnswerItalian": "Sì, eccolo qui.", "correctAnswerEnglish": "Yes, here it is.", "feedback": {"correctItalian": "Giusto! Risposta affermativa.", "incorrectItalian": "No, lo consegna.", "correctEnglish": "Right! Affirmative response.", "incorrectEnglish": "No, he's handing it over."}},
  {"id": "s49-p7", "choicesItalian": ["Preferisce il cambio?", "Vuole un caffè?", "Le piace questo?", "Viene domani?"], "choicesEnglish": ["Do you prefer an exchange?", "Do you want a coffee?", "Do you like this?", "Are you coming tomorrow?"], "correctAnswerItalian": "Preferisce il cambio?", "correctAnswerEnglish": "Do you prefer an exchange?", "feedback": {"correctItalian": "Molto bene! Offerta di sostituzione.", "incorrectItalian": "No, offre il cambio.", "correctEnglish": "Very well! Exchange offer.", "incorrectEnglish": "No, he's offering an exchange."}},
  {"id": "s49-p8", "choicesItalian": ["Voglio il rimborso.", "Voglio un regalo.", "Voglio uscire.", "Voglio sognare."], "choicesEnglish": ["I want a refund.", "I want a gift.", "I want to go out.", "I want to dream."], "correctAnswerItalian": "Voglio il rimborso.", "correctAnswerEnglish": "I want a refund.", "feedback": {"correctItalian": "Ottimo! Chiede i soldi indietro.", "incorrectItalian": "No, vuole il rimborso.", "correctEnglish": "Great! Asking for money back.", "incorrectEnglish": "No, he wants a refund."}},
  {"id": "s49-p9", "choicesItalian": ["Emettiamo un buono.", "Diamo dei fiori.", "Facciamo una festa.", "Andiamo via."], "choicesEnglish": ["We issue a voucher.", "We give flowers.", "We have a party.", "We go away."], "correctAnswerItalian": "Emettiamo un buono.", "correctAnswerEnglish": "We issue a voucher.", "feedback": {"correctItalian": "Bene! Politica del negozio.", "incorrectItalian": "No, emettono un buono.", "correctEnglish": "Good! Store policy.", "incorrectEnglish": "No, they issue a voucher."}},
  {"id": "s49-p10", "choicesItalian": ["È troppo piccolo.", "È troppo grande.", "È molto bello.", "È di seta."], "choicesEnglish": ["It's too small.", "It's too big.", "It's very beautiful.", "It's made of silk."], "correctAnswerItalian": "È troppo piccolo.", "correctAnswerEnglish": "It's too small.", "feedback": {"correctItalian": "Esatto! Problema di taglia.", "incorrectItalian": "No, è piccolo.", "correctEnglish": "Exactly! Size issue.", "incorrectEnglish": "No, it's small."}},
  {"id": "s49-p11", "choicesItalian": ["Mi serve il 39.", "Voglio il 40.", "Ho preso il 38.", "Dov'è il 37?"], "choicesEnglish": ["I need size 39.", "I want size 40.", "I took size 38.", "Where is 37?"], "correctAnswerItalian": "Mi serve il 39.", "correctAnswerEnglish": "I need size 39.", "feedback": {"correctItalian": "Giusto! Specifica la misura.", "incorrectItalian": "No, gli serve il 39.", "correctEnglish": "Right! Specifies the size.", "incorrectEnglish": "No, he needs 39."}},
  {"id": "s49-p12", "choicesItalian": ["È esaurito.", "È disponibile.", "È in vetrina.", "È arrivato."], "choicesEnglish": ["It's sold out.", "It's available.", "It's in the window.", "It has arrived."], "correctAnswerItalian": "È esaurito.", "correctAnswerEnglish": "It's sold out.", "feedback": {"correctItalian": "Bene! Non c'è più.", "incorrectItalian": "No, è finito.", "correctEnglish": "Good! It's gone.", "incorrectEnglish": "No, it's sold out."}},
  {"id": "s49-p13", "choicesItalian": ["Validità di sei mesi.", "Durata di un anno.", "Scadenza domani.", "Valido per sempre."], "choicesEnglish": ["Validity of six months.", "Duration of one year.", "Expires tomorrow.", "Valid forever."], "correctAnswerItalian": "Validità di sei mesi.", "correctAnswerEnglish": "Validity of six months.", "feedback": {"correctItalian": "Esatto! Tempo d'uso del buono.", "incorrectItalian": "No, sono sei mesi.", "correctEnglish": "Exactly! Time of use for the voucher.", "incorrectEnglish": "No, it's six months."}},
  {"id": "s49-p14", "choicesItalian": ["Lo scontrino di cortesia.", "Un biglietto d'auguri.", "La carta d'identità.", "Il codice fiscale."], "choicesEnglish": ["The gift receipt.", "A greeting card.", "The ID card.", "The tax code."], "correctAnswerItalian": "Lo scontrino di cortesia.", "correctAnswerEnglish": "The gift receipt.", "feedback": {"correctItalian": "Ottimo! Per i resi dei regali.", "incorrectItalian": "No, è quello di cortesia.", "correctEnglish": "Great! For gift returns.", "incorrectEnglish": "No, it's the gift receipt."}},
  {"id": "s49-p15", "choicesItalian": ["Non è il mio stile.", "È perfetto per me.", "Mi piace molto.", "Lo indosserò ora."], "choicesEnglish": ["It's not my style.", "It's perfect for me.", "I like it a lot.", "I'll wear it now."], "correctAnswerItalian": "Non è il mio stile.", "correctAnswerEnglish": "It's not my style.", "feedback": {"correctItalian": "Bene! Motivo soggettivo del reso.", "incorrectItalian": "No, non è il suo stile.", "correctEnglish": "Good! Subjective reason for return.", "incorrectEnglish": "No, it's not his style."}},
  {"id": "s49-p16", "choicesItalian": ["Può scegliere altro.", "Deve andare via.", "Non può cambiare.", "Paghi la differenza."], "choicesEnglish": ["You can choose something else.", "You must leave.", "You cannot exchange.", "Pay the difference."], "correctAnswerItalian": "Può scegliere altro.", "correctAnswerEnglish": "You can choose something else.", "feedback": {"correctItalian": "Esatto! Libertà di scelta.", "incorrectItalian": "No, può scegliere.", "correctEnglish": "Exactly! Freedom of choice.", "incorrectEnglish": "No, he can choose."}},
  {"id": "s49-p17", "choicesItalian": ["Vado a fare un giro.", "Vado a casa.", "Vado a dormire.", "Vado al lavoro."], "choicesEnglish": ["I'm going to look around.", "I'm going home.", "I'm going to sleep.", "I'm going to work."], "correctAnswerItalian": "Vado a fare un giro.", "correctAnswerEnglish": "I'm going to look around.", "feedback": {"correctItalian": "Bene! Per cercare un altro articolo.", "incorrectItalian": "No, fa un giro.", "correctEnglish": "Good! To look for another item.", "incorrectEnglish": "No, he's looking around."}},
  {"id": "s49-p18", "choicesItalian": ["Lo abbiamo uguale.", "È l'ultimo rimasto.", "È di un altro colore.", "È rotto anche questo."], "choicesEnglish": ["We have the same one.", "It's the last one left.", "It's a different color.", "This one is broken too."], "correctAnswerItalian": "Lo abbiamo uguale.", "correctAnswerEnglish": "We have the same one.", "feedback": {"correctItalian": "Esatto! Disponibilità per il cambio.", "incorrectItalian": "No, ne hanno uno uguale.", "correctEnglish": "Exactly! Availability for exchange.", "incorrectEnglish": "No, they have the same one."}},
  {"id": "s49-p19", "choicesItalian": ["Per lo stesso valore.", "A metà prezzo.", "Gratis per lei.", "Molto più caro."], "choicesEnglish": ["For the same value.", "At half price.", "Free for you.", "Much more expensive."], "correctAnswerItalian": "Per lo stesso valore.", "correctAnswerEnglish": "For the same value.", "feedback": {"correctItalian": "Giusto! Parità di prezzo nel cambio.", "incorrectItalian": "No, stesso valore.", "correctEnglish": "Right! Price parity in exchange.", "incorrectEnglish": "No, same value."}},
  {"id": "s49-p20", "choicesItalian": ["Mi dispiace molto.", "Sono felice.", "Non mi interessa.", "È colpa sua."], "choicesEnglish": ["I'm very sorry.", "I'm happy.", "I don't care.", "It's your fault."], "correctAnswerItalian": "Mi dispiace molto.", "correctAnswerEnglish": "I'm very sorry.", "feedback": {"correctItalian": "Bene! Cortesia del commesso.", "incorrectItalian": "No, si scusa.", "correctEnglish": "Good! Clerk's courtesy.", "incorrectEnglish": "No, he apologizes."}},
  {"id": "s49-p21", "choicesItalian": ["È troppo largo.", "È troppo stretto.", "È perfetto.", "È di lana."], "choicesEnglish": ["It's too wide.", "It's too tight.", "It's perfect.", "It's made of wool."], "correctAnswerItalian": "È troppo largo.", "correctAnswerEnglish": "It's too wide.", "feedback": {"correctItalian": "Esatto! Altro problema di vestibilità.", "incorrectItalian": "No, è largo.", "correctEnglish": "Exactly! Another fit issue.", "incorrectEnglish": "No, it's wide."}},
  {"id": "s49-p22", "choicesItalian": ["Posso provarlo?", "Posso comprarlo?", "Posso portarlo?", "Posso lasciarlo?"], "choicesEnglish": ["Can I try it on?", "Can I buy it?", "Can I carry it?", "Can I leave it?"], "correctAnswerItalian": "Posso provarlo?", "correctAnswerEnglish": "Can I try it on?", "feedback": {"correctItalian": "Giusto! Per evitare errori.", "incorrectItalian": "No, vuole provarlo.", "correctEnglish": "Right! To avoid mistakes.", "incorrectEnglish": "No, he wants to try it on."}},
  {"id": "s49-p23", "choicesItalian": ["Dov'è il camerino?", "Dov'è il bagno?", "Dov'è l'uscita?", "Dov'è il bar?"], "choicesEnglish": ["Where is the fitting room?", "Where is the bathroom?", "Where is the exit?", "Where is the bar?"], "correctAnswerItalian": "Dov'è il camerino?", "correctAnswerEnglish": "Where is the fitting room?", "feedback": {"correctItalian": "Bene! Luogo della prova.", "incorrectItalian": "No, cerca il camerino.", "correctEnglish": "Good! Place for trying on.", "incorrectEnglish": "No, he's looking for the fitting room."}},
  {"id": "s49-p24", "choicesItalian": ["L'etichetta è intatta.", "L'etichetta è tolta.", "Il vestito è sporco.", "Il sacco è vuoto."], "choicesEnglish": ["The tag is intact.", "The tag is removed.", "The dress is dirty.", "The bag is empty."], "correctAnswerItalian": "L'etichetta è intatta.", "correctAnswerEnglish": "The tag is intact.", "feedback": {"correctItalian": "Esatto! Condizione per il reso.", "incorrectItalian": "No, l'etichetta c'è.", "correctEnglish": "Exactly! Condition for return.", "incorrectEnglish": "No, the tag is there."}},
  {"id": "s49-p25", "choicesItalian": ["Non è mai stato usato.", "È stato lavato.", "È molto vecchio.", "È un regalo usato."], "choicesEnglish": ["It has never been used.", "It has been washed.", "It's very old.", "It's a used gift."], "correctAnswerItalian": "Non è mai stato usato.", "correctAnswerEnglish": "It has never been used.", "feedback": {"correctItalian": "Giusto! Condizione di novità.", "incorrectItalian": "No, non è usato.", "correctEnglish": "Right! Condition of novelty.", "incorrectEnglish": "No, it's not used."}},
  {"id": "s49-p26", "choicesItalian": ["Nella confezione originale.", "In una busta rotta.", "Senza scatola.", "Sopra il tavolo."], "choicesEnglish": ["In the original packaging.", "In a broken bag.", "Without a box.", "On the table."], "correctAnswerItalian": "Nella confezione originale.", "correctAnswerEnglish": "In the original packaging.", "feedback": {"correctItalian": "Bene! Importante per il reso.", "incorrectItalian": "No, ha la confezione.", "correctEnglish": "Good! Important for return.", "incorrectEnglish": "No, it has the packaging."}},
  {"id": "s49-p27", "choicesItalian": ["C'è un difetto di fabbrica.", "È colpa mia.", "Mi piace così.", "È un pezzo unico."], "choicesEnglish": ["There's a factory defect.", "It's my fault.", "I like it this way.", "It's a unique piece."], "correctAnswerItalian": "C'è un difetto di fabbrica.", "correctAnswerEnglish": "There's a factory defect.", "feedback": {"correctItalian": "Esatto! Motivo oggettivo.", "incorrectItalian": "No, è un difetto di fabbrica.", "correctEnglish": "Exactly! Objective reason.", "incorrectEnglish": "No, it's a factory defect."}},
  {"id": "s49-p28", "choicesItalian": ["Posso parlare con il responsabile?", "Posso avere un caffè?", "Posso andare via?", "Posso pagare dopo?"], "choicesEnglish": ["Can I speak with the manager?", "Can I have a coffee?", "Can I go away?", "Can I pay later?"], "correctAnswerItalian": "Posso parlare con il responsabile?", "correctAnswerEnglish": "Can I speak with the manager?", "feedback": {"correctItalian": "Giusto! Per problemi complessi.", "incorrectItalian": "No, vuole il responsabile.", "correctEnglish": "Right! For complex issues.", "incorrectEnglish": "No, he wants the manager."}},
  {"id": "s49-p29", "choicesItalian": ["Deve firmare qui.", "Deve andare lì.", "Deve pagare ancora.", "Deve uscire subito."], "choicesEnglish": ["You must sign here.", "You must go there.", "You must pay more.", "You must leave now."], "correctAnswerItalian": "Deve firmare qui.", "correctAnswerEnglish": "You must sign here.", "feedback": {"correctItalian": "Bene! Procedura del reso.", "incorrectItalian": "No, chiede la firma.", "correctEnglish": "Good! Return procedure.", "incorrectEnglish": "No, he's asking for a signature."}},
  {"id": "s49-p30", "choicesItalian": ["Ecco il suo buono.", "Ecco i suoi soldi.", "Ecco il suo regalo.", "Ecco la porta."], "choicesEnglish": ["Here is your voucher.", "Here is your money.", "Here is your gift.", "Here is the door."], "correctAnswerItalian": "Ecco il suo buono.", "correctAnswerEnglish": "Here is your voucher.", "feedback": {"correctItalian": "Esatto! Consegna del credito.", "incorrectItalian": "No, è il buono.", "correctEnglish": "Exactly! Delivery of credit.", "incorrectEnglish": "No, it's the voucher."}},
  {"id": "s49-p31", "choicesItalian": ["Voglio cambiare colore.", "Voglio cambiare vita.", "Voglio cambiare casa.", "Voglio cambiare borsa."], "choicesEnglish": ["I want to change the color.", "I want to change my life.", "I want to change my house.", "I want to change my bag."], "correctAnswerItalian": "Voglio cambiare colore.", "correctAnswerEnglish": "I want to change the color.", "feedback": {"correctItalian": "Giusto! Richiesta di variante.", "incorrectItalian": "No, vuole un altro colore.", "correctEnglish": "Right! Variant request.", "incorrectEnglish": "No, he wants another color."}},
  {"id": "s49-p32", "choicesItalian": ["Questo è macchiato.", "Questo è pulito.", "Questo è nuovo.", "Questo è caro."], "choicesEnglish": ["This is stained.", "This is clean.", "This is new.", "This is expensive."], "correctAnswerItalian": "Questo è macchiato.", "correctAnswerEnglish": "This is stained.", "feedback": {"correctItalian": "Bene! Altro difetto visibile.", "incorrectItalian": "No, è macchiato.", "correctEnglish": "Good! Another visible defect.", "incorrectEnglish": "No, it's stained."}},
  {"id": "s49-p33", "choicesItalian": ["Non funziona bene.", "Va a meraviglia.", "È rotto del tutto.", "È perfetto."], "choicesEnglish": ["It's not working well.", "It works wonderfully.", "It's completely broken.", "It's perfect."], "correctAnswerItalian": "Non funziona bene.", "correctAnswerEnglish": "It's not working well.", "feedback": {"correctItalian": "Esatto! Per apparecchi elettronici.", "incorrectItalian": "No, non funziona.", "correctEnglish": "Exactly! For electronic devices.", "incorrectEnglish": "No, it's not working."}},
  {"id": "s49-p34", "choicesItalian": ["È ancora in garanzia.", "La garanzia è scaduta.", "Non c'è garanzia.", "Che cos'è la garanzia?"], "choicesEnglish": ["It's still under warranty.", "The warranty has expired.", "There is no warranty.", "What is a warranty?"], "correctAnswerItalian": "È ancora in garanzia.", "correctAnswerEnglish": "It's still under warranty.", "feedback": {"correctItalian": "Giusto! Protezione attiva.", "incorrectItalian": "No, ha la garanzia.", "correctEnglish": "Right! Active protection.", "incorrectEnglish": "No, it has a warranty."}},
  {"id": "s49-p35", "choicesItalian": ["Posso avere un rimborso?", "Posso avere un regalo?", "Posso avere uno sconto?", "Posso avere pace?"], "choicesEnglish": ["Can I have a refund?", "Can I have a gift?", "Can I have a discount?", "Can I have peace?"], "correctAnswerItalian": "Posso avere un rimborso?", "correctAnswerEnglish": "Can I have a refund?", "feedback": {"correctItalian": "Bene! Chiede i soldi.", "incorrectItalian": "No, vuole il rimborso.", "correctEnglish": "Good! Asking for money.", "incorrectEnglish": "No, he wants a refund."}},
  {"id": "s49-p36", "choicesItalian": ["Secondo le regole.", "Come mi pare.", "Senza motivo.", "Per gioco."], "choicesEnglish": ["According to the rules.", "As I please.", "Without reason.", "For fun."], "correctAnswerItalian": "Secondo le regole.", "correctAnswerEnglish": "According to the rules.", "feedback": {"correctItalian": "Esatto! Rispetto delle norme.", "incorrectItalian": "No, segue le regole.", "correctEnglish": "Exactly! Respecting norms.", "incorrectEnglish": "No, he's following the rules."}},
  {"id": "s49-p37", "choicesItalian": ["Quale sarebbe il problema?", "Cosa vuole ora?", "Chi è lei?", "Dove va?"], "choicesEnglish": ["What would the problem be?", "What do you want now?", "Who are you?", "Where are you going?"], "correctAnswerItalian": "Quale sarebbe il problema?", "correctAnswerEnglish": "What would the problem be?", "feedback": {"correctItalian": "Giusto! Domanda del commesso.", "incorrectItalian": "No, chiede del problema.", "correctEnglish": "Right! Clerk's question.", "incorrectEnglish": "No, he's asking about the problem."}},
  {"id": "s49-p38", "choicesItalian": ["Mi sono accorto tardi.", "L'ho visto subito.", "Non l'ho mai visto.", "Sempre lo stesso."], "choicesEnglish": ["I noticed late.", "I saw it immediately.", "I never saw it.", "Always the same."], "correctAnswerItalian": "Mi sono accorto tardi.", "correctAnswerEnglish": "I noticed late.", "feedback": {"correctItalian": "Bene! Spiega il ritardo.", "incorrectItalian": "No, l'ha notato dopo.", "correctEnglish": "Good! Explains the delay.", "incorrectEnglish": "No, he noticed it later."}},
  {"id": "s49-p39", "choicesItalian": ["Lo scontrino è obbligatorio.", "Lo scontrino è inutile.", "Non serve nulla.", "Butti via tutto."], "choicesEnglish": ["The receipt is mandatory.", "The receipt is useless.", "Nothing is needed.", "Throw everything away."], "correctAnswerItalian": "Lo scontrino è obbligatorio.", "correctAnswerEnglish": "The receipt is mandatory.", "feedback": {"correctItalian": "Esatto! Senza non si fa nulla.", "incorrectItalian": "No, è obbligatorio.", "correctEnglish": "Exactly! Without it, nothing can be done.", "incorrectEnglish": "No, it's mandatory."}},
  {"id": "s49-p40", "choicesItalian": ["Preferirei il cambio.", "Voglio il buono.", "Mi dia i soldi.", "Prendo altro."], "choicesEnglish": ["I would prefer an exchange.", "I want the voucher.", "Give me the money.", "I'll take something else."], "correctAnswerItalian": "Preferirei il cambio.", "correctAnswerEnglish": "I would prefer an exchange.", "feedback": {"correctItalian": "Giusto! Scelta tra le opzioni.", "incorrectItalian": "No, vuole il cambio.", "correctEnglish": "Right! Choice among options.", "incorrectEnglish": "No, he wants an exchange."}},
  {"id": "s49-p41", "choicesItalian": ["Vado a vedere subito.", "Non voglio guardare.", "Guardi lei.", "Dopo con calma."], "choicesEnglish": ["I'll go see right away.", "I don't want to look.", "You look.", "Later, calmly."], "correctAnswerItalian": "Vado a vedere subito.", "correctAnswerEnglish": "I'll go see right away.", "feedback": {"correctItalian": "Bene! Controllo in magazzino.", "incorrectItalian": "No, va a vedere.", "correctEnglish": "Good! Checking in the stockroom.", "incorrectEnglish": "No, he's going to check."}},
  {"id": "s49-p42", "choicesItalian": ["In questo colore è finito.", "Ne abbiamo molti.", "C'è solo questo.", "È un brutto colore."], "choicesEnglish": ["In this color it's finished.", "We have many.", "There's only this one.", "It's an ugly color."], "correctAnswerItalian": "In questo colore è finito.", "correctAnswerEnglish": "In this color it's finished.", "feedback": {"correctItalian": "Esatto! Indisponibilità specifica.", "incorrectItalian": "No, è finito quel colore.", "correctEnglish": "Exactly! Specific unavailability.", "incorrectEnglish": "No, that color is sold out."}},
  {"id": "s49-p43", "choicesItalian": ["Le va bene lo stesso?", "Non le piace?", "Cosa fa ora?", "È un problema?"], "choicesEnglish": ["Is it okay for you anyway?", "Don't you like it?", "What are you doing now?", "Is it a problem?"], "correctAnswerItalian": "Le va bene lo stesso?", "correctAnswerEnglish": "Is it okay for you anyway?", "feedback": {"correctItalian": "Giusto! Chiede conferma.", "incorrectItalian": "No, chiede se va bene.", "correctEnglish": "Right! Asking for confirmation.", "incorrectEnglish": "No, he's asking if it's okay."}},
  {"id": "s49-p44", "choicesItalian": ["Va bene lo stesso.", "No, non mi va.", "Forse sì.", "Non saprei."], "choicesEnglish": ["It's okay anyway.", "No, I don't feel like it.", "Maybe yes.", "I wouldn't know."], "correctAnswerItalian": "Va bene lo stesso.", "correctAnswerEnglish": "It's okay anyway.", "feedback": {"correctItalian": "Bene! Accettazione.", "incorrectItalian": "No, accetta.", "correctEnglish": "Good! Acceptance.", "incorrectEnglish": "No, he accepts."}},
  {"id": "s49-p45", "choicesItalian": ["Mi hanno regalato questo.", "L'ho comprato io.", "È caduto per strada.", "L'ho trovato."], "choicesEnglish": ["They gave me this as a gift.", "I bought it myself.", "It fell on the road.", "I found it."], "correctAnswerItalian": "Mi hanno regalato questo.", "correctAnswerEnglish": "They gave me this as a gift.", "feedback": {"correctItalian": "Esatto! Caso di regalo.", "incorrectItalian": "No, è un regalo.", "correctEnglish": "Exactly! Gift case.", "incorrectEnglish": "No, it's a gift."}},
  {"id": "s49-p46", "choicesItalian": ["È troppo stretto qui.", "È molto largo lì.", "Va bene ovunque.", "È rovinato."], "choicesEnglish": ["It's too tight here.", "It's very wide there.", "It fits everywhere.", "It's ruined."], "correctAnswerItalian": "È troppo stretto qui.", "correctAnswerEnglish": "It's too tight here.", "feedback": {"correctItalian": "Giusto! Problema localizzato.", "incorrectItalian": "No, è stretto.", "correctEnglish": "Right! Localized issue.", "incorrectEnglish": "No, it's tight."}},
