[
  {"id": "s50-p1", "choicesItalian": ["Posso pagare con la carta?", "Voglio un caffè nero.", "Dov'è il bagno?", "Quanto costa il pane?"], "choicesEnglish": ["Can I pay by card?", "I want a black coffee.", "Where is the bathroom?", "How much is the bread?"], "correctAnswerItalian": "Posso pagare con la carta?", "correctAnswerEnglish": "Can I pay by card?", "feedback": {"correctItalian": "Esatto! La domanda principale per questo scenario.", "incorrectItalian": "No, chiede di pagare con la carta.", "correctEnglish": "Exactly! The main question for this scenario.", "incorrectEnglish": "No, he's asking to pay by card."}},
  {"id": "s50-p2", "choicesItalian": ["Accettate il bancomat?", "Avete dei dolci?", "Siete aperti ora?", "Chi è il capo?"], "choicesEnglish": ["Do you accept debit cards?", "Do you have any sweets?", "Are you open now?", "Who is the boss?"], "correctAnswerItalian": "Accettate il bancomat?", "correctAnswerEnglish": "Do you accept debit cards?", "feedback": {"correctItalian": "Bene! Per verificare se accettano pagamenti elettronici.", "incorrectItalian": "No, chiede del bancomat.", "correctEnglish": "Good! To check if they accept electronic payments.", "incorrectEnglish": "No, he's asking about the debit card."}},
  {"id": "s50-p3", "choicesItalian": ["Appoggi pure qui sopra.", "Vada via subito.", "Si sieda al tavolo.", "Mangi pure tutto."], "choicesEnglish": ["Just tap it right here.", "Go away immediately.", "Sit at the table.", "Go ahead and eat everything."], "correctAnswerItalian": "Appoggi pure qui sopra.", "correctAnswerEnglish": "Just tap it right here.", "feedback": {"correctItalian": "Ottimo! Istruzione per il pagamento contactless.", "incorrectItalian": "No, dice di appoggiare la carta.", "correctEnglish": "Great! Instruction for contactless payment.", "incorrectEnglish": "No, he says to tap the card."}},
  {"id": "s50-p4", "choicesItalian": ["Riprovi, per favore.", "Si fermi lì.", "Torni domani.", "Non faccia nulla."], "choicesEnglish": ["Try again, please.", "Stop right there.", "Come back tomorrow.", "Do nothing."], "correctAnswerItalian": "Riprovi, per favore.", "correctAnswerEnglish": "Try again, please.", "feedback": {"correctItalian": "Bene! Quando il primo tentativo fallisce.", "incorrectItalian": "No, chiede di riprovare.", "correctEnglish": "Good! When the first attempt fails.", "incorrectEnglish": "No, he's asking to try again."}},
  {"id": "s50-p5", "choicesItalian": ["Non ha letto il chip.", "Non ha visto il gatto.", "Non ha sentito nulla.", "Non ha fame."], "choicesEnglish": ["It didn't read the chip.", "It didn't see the cat.", "It didn't hear anything.", "It wasn't hungry."], "correctAnswerItalian": "Non ha letto il chip.", "correctAnswerEnglish": "It didn't read the chip.", "feedback": {"correctItalian": "Esatto! Problema tecnico comune.", "incorrectItalian": "No, il problema è il chip.", "correctEnglish": "Exactly! Common technical problem.", "incorrectEnglish": "No, the problem is the chip."}},
  {"id": "s50-p6", "choicesItalian": ["Provo a inserirla?", "Provo a romperla?", "Provo a lanciarla?", "Provo a mangiarla?"], "choicesEnglish": ["Should I try inserting it?", "Should I try breaking it?", "Should I try throwing it?", "Should I try eating it?"], "correctAnswerItalian": "Provo a inserirla?", "correctAnswerEnglish": "Should I try inserting it?", "feedback": {"correctItalian": "Giusto! Alternativa al contactless.", "incorrectItalian": "No, vuole inserirla nel POS.", "correctEnglish": "Right! Alternative to contactless.", "incorrectEnglish": "No, he wants to insert it into the POS."}},
  {"id": "s50-p7", "choicesItalian": ["Transazione negata.", "Festa finita.", "Viaggio annullato.", "Lavoro completato."], "choicesEnglish": ["Transaction denied.", "Party over.", "Trip cancelled.", "Work completed."], "correctAnswerItalian": "Transazione negata.", "correctAnswerEnglish": "Transaction denied.", "feedback": {"correctItalian": "Molto bene! Il messaggio di errore del POS.", "incorrectItalian": "No, il pagamento è negato.", "correctEnglish": "Very well! The POS error message.", "incorrectEnglish": "No, the payment is denied."}},
  {"id": "s50-p8", "choicesItalian": ["Ha un'altra carta?", "Ha un altro cane?", "Ha un'altra casa?", "Ha un altro amico?"], "choicesEnglish": ["Do you have another card?", "Do you have another dog?", "Do you have another house?", "Do you have another friend?"], "correctAnswerItalian": "Ha un'altra carta?", "correctAnswerEnglish": "Do you have another card?", "feedback": {"correctItalian": "Ottimo! Soluzione proposta dal barista.", "incorrectItalian": "No, chiede un'altra carta.", "correctEnglish": "Great! Solution proposed by the barista.", "incorrectEnglish": "No, he's asking for another card."}},
  {"id": "s50-p9", "choicesItalian": ["Provo con il telefono.", "Provo con la testa.", "Provo con il piede.", "Provo con il sasso."], "choicesEnglish": ["I'll try with my phone.", "I'll try with my head.", "I'll try with my foot.", "I'll try with the stone."], "correctAnswerItalian": "Provo con il telefono.", "correctAnswerEnglish": "I'll try with my phone.", "feedback": {"correctItalian": "Bene! Uso del pagamento digitale mobile.", "incorrectItalian": "No, usa il telefono.", "correctEnglish": "Good! Use of mobile digital payment.", "incorrectEnglish": "No, he's using the phone."}},
  {"id": "s50-p10", "choicesItalian": ["Ecco lo scontrino.", "Ecco il libro.", "Ecco il regalo.", "Ecco la borsa."], "choicesEnglish": ["Here is the receipt.", "Here is the book.", "Here is the gift.", "Here is the bag."], "correctAnswerItalian": "Ecco lo scontrino.", "correctAnswerEnglish": "Here is the receipt.", "feedback": {"correctItalian": "Esatto! Documento di fine transazione.", "incorrectItalian": "No, consegna lo scontrino.", "correctEnglish": "Exactly! End of transaction document.", "incorrectEnglish": "No, he's handing over the receipt."}},
  {"id": "s50-p11", "choicesItalian": ["Per importi piccoli.", "Per case grandi.", "Per viaggi lunghi.", "Per cani piccoli."], "choicesEnglish": ["For small amounts.", "For large houses.", "For long trips.", "For small dogs."], "correctAnswerItalian": "Per importi piccoli.", "correctAnswerEnglish": "For small amounts.", "feedback": {"correctItalian": "Giusto! Riferito a pagamenti di pochi euro.", "incorrectItalian": "No, parla di importi piccoli.", "correctEnglish": "Right! Referring to payments of a few euros.", "incorrectEnglish": "No, it's about small amounts."}},
  {"id": "s50-p12", "choicesItalian": ["Accettiamo tutto.", "Non accettiamo nulla.", "Solo contanti.", "Solo sassi."], "choicesEnglish": ["We accept everything.", "We don't accept anything.", "Only cash.", "Only stones."], "correctAnswerItalian": "Accettiamo tutto.", "correctAnswerEnglish": "We accept everything.", "feedback": {"correctItalian": "Bene! Disponibilità totale di pagamento.", "incorrectItalian": "No, accettano tutto.", "correctEnglish": "Good! Total payment availability.", "incorrectEnglish": "No, they accept everything."}},
  {"id": "s50-p13", "choicesItalian": ["Non ho contanti con me.", "Non ho amici qui.", "Non ho fame ora.", "Non ho voglia di uscire."], "choicesEnglish": ["I don't have cash with me.", "I don't have friends here.", "I'm not hungry now.", "I don't feel like going out."], "correctAnswerItalian": "Non ho contanti con me.", "correctAnswerEnglish": "I don't have cash with me.", "feedback": {"correctItalian": "Esatto! Motivo per usare la carta.", "incorrectItalian": "No, non ha contanti.", "correctEnglish": "Exactly! Reason for using the card.", "incorrectEnglish": "No, he doesn't have cash."}},
  {"id": "s50-p14", "choicesItalian": ["È un suo diritto.", "È un suo dovere.", "È un suo sogno.", "È un suo errore."], "choicesEnglish": ["It's your right.", "It's your duty.", "It's your dream.", "It's your error."], "correctAnswerItalian": "È un suo diritto.", "correctAnswerEnglish": "It's your right.", "feedback": {"correctItalian": "Ottimo! Riferito all'obbligo del POS.", "incorrectItalian": "No, parla di un diritto.", "correctEnglish": "Great! Referring to the POS obligation.", "incorrectEnglish": "No, it's about a right."}},
  {"id": "s50-p15", "choicesItalian": ["Può fare contactless.", "Deve correre forte.", "Può saltare alto.", "Deve stare zitto."], "choicesEnglish": ["You can do contactless.", "You must run fast.", "You can jump high.", "You must keep quiet."], "correctAnswerItalian": "Può fare contactless.", "correctAnswerEnglish": "You can do contactless.", "feedback": {"correctItalian": "Bene! Suggerimento del commesso.", "incorrectItalian": "No, suggerisce il contactless.", "correctEnglish": "Good! Clerk's suggestion.", "incorrectEnglish": "No, he suggests contactless."}},
  {"id": "s50-p16", "choicesItalian": ["Devo inserire il PIN?", "Devo dire il nome?", "Devo dare un bacio?", "Devo andare via?"], "choicesEnglish": ["Do I have to enter the PIN?", "Do I have to say the name?", "Do I have to give a kiss?", "Do I have to go away?"], "correctAnswerItalian": "Devo inserire il PIN?", "correctAnswerEnglish": "Do I have to enter the PIN?", "feedback": {"correctItalian": "Esatto! Per autorizzare la spesa.", "incorrectItalian": "No, chiede del PIN.", "correctEnglish": "Exactly! To authorize the expense.", "incorrectEnglish": "No, he's asking about the PIN."}},
  {"id": "s50-p17", "choicesItalian": ["Sotto i cinquanta euro.", "Sopra i cento euro.", "Senza soldi.", "Con molti amici."], "choicesEnglish": ["Under fifty euros.", "Over a hundred euros.", "Without money.", "With many friends."], "correctAnswerItalian": "Sotto i cinquanta euro.", "correctAnswerEnglish": "Under fifty euros.", "feedback": {"correctItalian": "Bene! Soglia per il PIN in Italia.", "incorrectItalian": "No, sotto i 50 euro.", "correctEnglish": "Good! PIN threshold in Italy.", "incorrectEnglish": "No, under 50 euros."}},
  {"id": "s50-p18", "choicesItalian": ["Vuole il sacchetto?", "Vuole un cornetto?", "Vuole la luna?", "Vuole un libro?"], "choicesEnglish": ["Do you want the bag?", "Do you want a croissant?", "Do you want the moon?", "Do you want a book?"], "correctAnswerItalian": "Vuole il sacchetto?", "correctAnswerEnglish": "Do you want the bag?", "feedback": {"correctItalian": "Esatto! Domanda finale di cortesia.", "incorrectItalian": "No, offre il sacchetto.", "correctEnglish": "Exactly! Final courtesy question.", "incorrectEnglish": "No, he's offering the bag."}},
  {"id": "s50-p19", "choicesItalian": ["Ho la mia borsa.", "Ho il mio cane.", "Ho la mia casa.", "Ho la mia auto."], "choicesEnglish": ["I have my bag.", "I have my dog.", "I have my house.", "I have my car."], "correctAnswerItalian": "Ho la mia borsa.", "correctAnswerEnglish": "I have my bag.", "feedback": {"correctItalian": "Giusto! Per rifiutare il sacchetto.", "incorrectItalian": "No, ha la borsa.", "correctEnglish": "Right! To refuse the bag.", "incorrectEnglish": "No, he has the bag."}},
  {"id": "s50-p20", "choicesItalian": ["Ora è andata!", "Ora è rotta!", "Ora è persa!", "Ora è finita!"], "choicesEnglish": ["Now it went through!", "Now it's broken!", "Now it's lost!", "Now it's over!"], "correctAnswerItalian": "Ora è andata!", "correctAnswerEnglish": "Now it went through!", "feedback": {"correctItalian": "Bene! Successo del pagamento.", "incorrectItalian": "No, è andata bene.", "correctEnglish": "Good! Payment success.", "incorrectEnglish": "No, it went well."}},
  {"id": "s50-p21", "choicesItalian": ["In totale sono...", "In parte sono...", "Senza nulla sono...", "Con amore sono..."], "choicesEnglish": ["In total it is...", "In part it is...", "Without anything it is...", "With love it is..."], "correctAnswerItalian": "In totale sono...", "correctAnswerEnglish": "In total it is...", "feedback": {"correctItalian": "Esatto! Per annunciare il prezzo.", "incorrectItalian": "No, parla del totale.", "correctEnglish": "Exactly! To announce the price.", "incorrectEnglish": "No, it's about the total."}},
  {"id": "s50-p22", "choicesItalian": ["Accettate Apple Pay?", "Accettate sassi?", "Accettate fiori?", "Accettate baci?"], "choicesEnglish": ["Do you accept Apple Pay?", "Do you accept stones?", "Do you accept flowers?", "Do you accept kisses?"], "correctAnswerItalian": "Accettate Apple Pay?", "correctAnswerEnglish": "Do you accept Apple Pay?", "feedback": {"correctItalian": "Giusto! Per pagamenti da smartphone.", "incorrectItalian": "No, chiede di Apple Pay.", "correctEnglish": "Right! For smartphone payments.", "incorrectEnglish": "No, he's asking for Apple Pay."}},
  {"id": "s50-p23", "choicesItalian": ["Non c'è campo.", "Non c'è pane.", "Non c'è acqua.", "Non c'è nessuno."], "choicesEnglish": ["There's no signal.", "There's no bread.", "There's no water.", "There's no one."], "correctAnswerItalian": "Non c'è campo.", "correctAnswerEnglish": "There's no signal.", "feedback": {"correctItalian": "Bene! Problema di connessione del POS.", "incorrectItalian": "No, manca il segnale.", "correctEnglish": "Good! POS connection problem.", "incorrectEnglish": "No, there's no signal."}},
  {"id": "s50-p24", "choicesItalian": ["Inserisca il codice.", "Scriva il nome.", "Dica la verità.", "Faccia un salto."], "choicesEnglish": ["Enter the code.", "Write the name.", "Tell the truth.", "Take a jump."], "correctAnswerItalian": "Inserisca il codice.", "correctAnswerEnglish": "Enter the code.", "feedback": {"correctItalian": "Esatto! Istruzione per il PIN.", "incorrectItalian": "No, chiede il codice.", "correctEnglish": "Exactly! Instruction for the PIN.", "incorrectEnglish": "No, he's asking for the code."}},
  {"id": "s50-p25", "choicesItalian": ["La carta è scaduta.", "La carta è nuova.", "La carta è blu.", "La carta è bella."], "choicesEnglish": ["The card has expired.", "The card is new.", "The card is blue.", "The card is beautiful."], "correctAnswerItalian": "La carta è scaduta.", "correctAnswerEnglish": "The card has expired.", "feedback": {"correctItalian": "Giusto! Altro motivo di rifiuto.", "incorrectItalian": "No, è scaduta.", "correctEnglish": "Right! Another reason for rejection.", "incorrectEnglish": "No, it's expired."}},
  {"id": "s50-p26", "choicesItalian": ["Prelevo al bancomat.", "Vado a casa.", "Mangio una pizza.", "Dormo un po'."], "choicesEnglish": ["I'll withdraw at the ATM.", "I'm going home.", "I'm eating a pizza.", "I'm sleeping a bit."], "correctAnswerItalian": "Prelevo al bancomat.", "correctAnswerEnglish": "I'll withdraw at the ATM.", "feedback": {"correctItalian": "Bene! Per prendere contanti.", "incorrectItalian": "No, preleva soldi.", "correctEnglish": "Good! To get cash.", "incorrectEnglish": "No, he's withdrawing money."}},
  {"id": "s50-p27", "choicesItalian": ["La linea è lenta.", "La torta è dolce.", "Il cane è veloce.", "Il mare è calmo."], "choicesEnglish": ["The line is slow.", "The cake is sweet.", "The dog is fast.", "The sea is calm."], "correctAnswerItalian": "La linea è lenta.", "correctAnswerEnglish": "The line is slow.", "feedback": {"correctItalian": "Esatto! Riferito alla connessione dati.", "incorrectItalian": "No, la linea è lenta.", "correctEnglish": "Exactly! Referring to the data connection.", "incorrectEnglish": "No, the line is slow."}},
  {"id": "s50-p28", "choicesItalian": ["Posso avere la copia?", "Posso avere un caffè?", "Posso andare via?", "Posso avere uno sconto?"], "choicesEnglish": ["Can I have the copy?", "Can I have a coffee?", "Can I go away?", "Can I have a discount?"], "correctAnswerItalian": "Posso avere la copia?", "correctAnswerEnglish": "Can I have the copy?", "feedback": {"correctItalian": "Giusto! Riferito alla ricevuta del POS.", "incorrectItalian": "No, vuole la copia dello scontrino.", "correctEnglish": "Right! Referring to the POS receipt.", "incorrectEnglish": "No, he wants the copy of the receipt."}},
  {"id": "s50-p29", "choicesItalian": ["Metta la firma qui.", "Metta il cappello.", "Metta la borsa.", "Metta il resto."], "choicesEnglish": ["Put the signature here.", "Put on the hat.", "Put the bag.", "Put the change."], "correctAnswerItalian": "Metta la firma qui.", "correctAnswerEnglish": "Put the signature here.", "feedback": {"correctItalian": "Bene! Per autorizzare senza PIN.", "incorrectItalian": "No, vuole la firma.", "correctEnglish": "Good! To authorize without a PIN.", "incorrectEnglish": "No, he wants the signature."}},
  {"id": "s50-p30", "choicesItalian": ["Pagamento approvato.", "Lavoro finito.", "Viaggio iniziato.", "Pasto servito."], "choicesEnglish": ["Payment approved.", "Work finished.", "Trip started.", "Meal served."], "correctAnswerItalian": "Pagamento approvato.", "correctAnswerEnglish": "Payment approved.", "feedback": {"correctItalian": "Esatto! Esito positivo finale.", "incorrectItalian": "No, è approvato.", "correctEnglish": "Exactly! Final positive result.", "incorrectEnglish": "No, it's approved."}},
  {"id": "s50-p31", "choicesItalian": ["La carta non funziona.", "La penna non scrive.", "Il cane non abbaia.", "Il sole non splende."], "choicesEnglish": ["The card doesn't work.", "The pen doesn't write.", "The dog doesn't bark.", "The sun doesn't shine."], "correctAnswerItalian": "La carta non funziona.", "correctAnswerEnglish": "The card doesn't work.", "feedback": {"correctItalian": "Giusto! Problema generico della carta.", "incorrectItalian": "No, non funziona.", "correctEnglish": "Right! Generic card problem.", "incorrectEnglish": "No, it doesn't work."}},
  {"id": "s50-p32", "choicesItalian": ["Devo rifare l'operazione.", "Devo andare al mare.", "Devo mangiare subito.", "Devo dormire molto."], "choicesEnglish": ["I have to redo the operation.", "I have to go to the sea.", "I have to eat immediately.", "I have to sleep a lot."], "correctAnswerItalian": "Devo rifare l'operazione.", "correctAnswerEnglish": "I have to redo the operation.", "feedback": {"correctItalian": "Bene! Quando c'è un errore tecnico.", "incorrectItalian": "No, deve rifare tutto.", "correctEnglish": "Good! When there's a technical error.", "incorrectEnglish": "No, he has to redo everything."}},
  {"id": "s50-p33", "choicesItalian": ["È una carta prepagata.", "È una casa grande.", "È un cane bravo.", "È un libro vecchio."], "choicesEnglish": ["It's a prepaid card.", "It's a large house.", "It's a good dog.", "It's an old book."], "correctAnswerItalian": "È una carta prepagata.", "correctAnswerEnglish": "It's a prepaid card.", "feedback": {"correctItalian": "Esatto! Specifica il tipo di carta.", "incorrectItalian": "No, è prepagata.", "correctEnglish": "Exactly! Specifies the card type.", "incorrectEnglish": "No, it's prepaid."}},
  {"id": "s50-p34", "choicesItalian": ["Non c'è più carta.", "Non c'è più pane.", "Non c'è più tempo.", "Non c'è più acqua."], "choicesEnglish": ["There's no more paper.", "There's no more bread.", "There's no more time.", "There's no more water."], "correctAnswerItalian": "Non c'è più carta.", "correctAnswerEnglish": "There's no more paper.", "feedback": {"correctItalian": "Giusto! Riferito al rotolo del POS.", "incorrectItalian": "No, manca la carta.", "correctEnglish": "Right! Referring to the POS roll.", "incorrectEnglish": "No, the paper is missing."}},
  {"id": "s50-p35", "choicesItalian": ["Il segnale è debole.", "Il caffè è amaro.", "Il vento è forte.", "Il mare è blu."], "choicesEnglish": ["The signal is weak.", "The coffee is bitter.", "The wind is strong.", "The sea is blue."], "correctAnswerItalian": "Il segnale è debole.", "correctAnswerEnglish": "The signal is weak.", "feedback": {"correctItalian": "Bene! Altro problema di rete.", "incorrectItalian": "No, il segnale è scarso.", "correctEnglish": "Good! Another network problem.", "incorrectEnglish": "No, the signal is weak."}},
  {"id": "s50-p36", "choicesItalian": ["Tenga lo scontrino.", "Tenga il cane.", "Tenga la borsa.", "Tenga il resto."], "choicesEnglish": ["Keep the receipt.", "Keep the dog.", "Keep the bag.", "Keep the change."], "correctAnswerItalian": "Tenga lo scontrino.", "correctAnswerEnglish": "Keep the receipt.", "feedback": {"correctItalian": "Esatto! Invito a conservarlo.", "incorrectItalian": "No, dice di tenerlo.", "correctEnglish": "Exactly! Invitation to keep it.", "incorrectEnglish": "No, he says to keep it."}},
  {"id": "s50-p37", "choicesItalian": ["Mi dia dei contanti.", "Mi dia dei fiori.", "Mi dia un bacio.", "Mi dia una mano."], "choicesEnglish": ["Give me some cash.", "Give me some flowers.", "Give me a kiss.", "Give me a hand."], "correctAnswerItalian": "Mi dia dei contanti.", "correctAnswerEnglish": "Give me some cash.", "feedback": {"correctItalian": "Giusto! Quando la carta non va.", "incorrectItalian": "No, vuole i contanti.", "correctEnglish": "Right! When the card doesn't work.", "incorrectEnglish": "No, he wants cash."}},
  {"id": "s50-p38", "choicesItalian": ["La transazione è annullata.", "La festa è iniziata.", "La scuola è chiusa.", "La porta è aperta."], "choicesEnglish": ["The transaction is cancelled.", "The party has started.", "The school is closed.", "The door is open."], "correctAnswerItalian": "La transazione è annullata.", "correctAnswerEnglish": "The transaction is cancelled.", "feedback": {"correctItalian": "Bene! Quando si ferma tutto.", "incorrectItalian": "No, è annullata.", "correctEnglish": "Good! When everything stops.", "incorrectEnglish": "No, it's cancelled."}},
  {"id": "s50-p39", "choicesItalian": ["Digitare sul tastierino.", "Cantare sotto la doccia.", "Correre nel parco.", "Dormire nel letto."], "choicesEnglish": ["Type on the keypad.", "Sing in the shower.", "Run in the park.", "Sleep in the bed."], "correctAnswerItalian": "Digitare sul tastierino.", "correctAnswerEnglish": "Type on the keypad.", "feedback": {"correctItalian": "Esatto! Azione per il PIN.", "incorrectItalian": "No, deve digitare.", "correctEnglish": "Exactly! Action for the PIN.", "incorrectEnglish": "No, he must type."}},
  {"id": "s50-p40", "choicesItalian": ["Non serve il PIN.", "Non serve il pane.", "Non serve il tempo.", "Non serve il sole."], "choicesEnglish": ["The PIN is not needed.", "Bread is not needed.", "Time is not needed.", "Sun is not needed."], "correctAnswerItalian": "Non serve il PIN.", "correctAnswerEnglish": "The PIN is not needed.", "feedback": {"correctItalian": "Giusto! Per piccoli importi contactless.", "incorrectItalian": "No, il PIN non serve.", "correctEnglish": "Right! For small contactless amounts.", "incorrectEnglish": "No, the PIN is not needed."}},
  {"id": "s50-p41", "choicesItalian": ["Posso pagare contactless?", "Posso andare al cinema?", "Posso avere un dolce?", "Posso sedermi qui?"], "choicesEnglish": ["Can I pay contactless?", "Can I go to the cinema?", "Can I have a dessert?", "Can I sit here?"], "correctAnswerItalian": "Posso pagare contactless?", "correctAnswerEnglish": "Can I pay contactless?", "feedback": {"correctItalian": "Bene! Domanda sulla tecnologia.", "incorrectItalian": "No, chiede del contactless.", "correctEnglish": "Good! Question about technology.", "incorrectEnglish": "No, he's asking about contactless."}},
  {"id": "s50-p42", "choicesItalian": ["La banca è chiusa.", "La banca è aperta.", "La banca è lontana.", "La banca è bella."], "choicesEnglish": ["The bank is closed.", "The bank is open.", "The bank is far away.", "The bank is beautiful."], "correctAnswerItalian": "La banca è chiusa.", "correctAnswerEnglish": "The bank is closed.", "feedback": {"correctItalian": "Esatto! Possibile causa di problemi.", "incorrectItalian": "No, è chiusa.", "correctEnglish": "Exactly! Possible cause of problems.", "incorrectEnglish": "No, it's closed."}},
  {"id": "s50-p43", "choicesItalian": ["Controlli il saldo.", "Controlli il cane.", "Controlli la posta.", "Controlli l'ora."], "choicesEnglish": ["Check the balance.", "Check the dog.", "Check the mail.", "Check the time."], "correctAnswerItalian": "Controlli il saldo.", "correctAnswerEnglish": "Check the balance.", "feedback": {"correctItalian": "Giusto! Per vedere se ci sono soldi.", "incorrectItalian": "No, deve guardare il saldo.", "correctEnglish": "Right! To see if there's money.", "incorrectEnglish": "No, he must check the balance."}},
  {"id": "s50-p44", "choicesItalian": ["Il pagamento è andato.", "Il treno è partito.", "Il film è finito.", "Il sole è calato."], "choicesEnglish": ["The payment went through.", "The train has left.", "The movie is over.", "The sun has set."], "correctAnswerItalian": "Il pagamento è andato.", "correctAnswerEnglish": "The payment went through.", "feedback": {"correctItalian": "Bene! Conferma informale.", "incorrectItalian": "No, è andata bene.", "correctEnglish": "Good! Informal confirmation.", "incorrectEnglish": "No, it went well."}},
  {"id": "s50-p45", "choicesItalian": ["Vuole una ricevuta?", "Vuole una pizza?", "Vuole un caffè?", "Vuole uscire?"], "choicesEnglish": ["Do you want a receipt?", "Do you want a pizza?", "Do you want a coffee?", "Do you want to go out?"], "correctAnswerItalian": "Vuole una ricevuta?", "correctAnswerEnglish": "Do you want a receipt?", "feedback": {"correctItalian": "Esatto! Offerta del documento.", "incorrectItalian": "No, offre la ricevuta.", "correctEnglish": "Exactly! Document offer.", "incorrectEnglish": "No, he's offering the receipt."}},
  {"id": "s50-p46", "choicesItalian": ["Grazie e arrivederci.", "Addio per sempre.", "Ciao a tutti.", "Salve caro."], "choicesEnglish": ["Thanks and goodbye.", "Goodbye forever.", "Hi everyone.", "Hello dear."], "correctAnswerItalian": "Grazie e arrivederci.", "correctAnswerEnglish": "Thanks and goodbye.", "feedback": {"correctItalian": "Giusto! Saluto finale.", "incorrectItalian": "No, saluta e ringrazia.", "correctEnglish": "Right! Final greeting.", "incorrectEnglish": "No, he's greeting and thanking."}},
