  {"id": "s48-p47", "choicesItalian": ["Ha la tessera fedeltà?", "Ha fame?", "Ha un cane?", "Ha lo scontrino?"], "choicesEnglish": ["Do you have the loyalty card?", "Are you hungry?", "Do you have a dog?", "Do you have the receipt?"], "correctAnswerItalian": "Ha la tessera fedeltà?", "correctAnswerEnglish": "Do you have the loyalty card?", "feedback": {"correctItalian": "Bene! Per accumulare punti.", "incorrectItalian": "No, chiede della tessera.", "correctEnglish": "Good! To accumulate points.", "incorrectEnglish": "No, he's asking about the card."}},
