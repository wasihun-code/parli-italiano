[
  {"id": "s48-p1", "choicesItalian": ["Sto cercando un libro.", "Voglio un giornale.", "Cerco un amico.", "Dov'è la piazza?"], "choicesEnglish": ["I'm looking for a book.", "I want a newspaper.", "I'm looking for a friend.", "Where is the square?"], "correctAnswerItalian": "Sto cercando un libro.", "correctAnswerEnglish": "I'm looking for a book.", "feedback": {"correctItalian": "Esatto! Una frase base per iniziare.", "incorrectItalian": "No, cerca un libro.", "correctEnglish": "Exactly! A basic phrase to start.", "incorrectEnglish": "No, he's looking for a book."}},
  {"id": "s48-p2", "choicesItalian": ["L'ultimo romanzo.", "Il primo libro.", "Un libro vecchio.", "Un saggio lungo."], "choicesEnglish": ["The latest novel.", "The first book.", "An old book.", "A long essay."], "correctAnswerItalian": "L'ultimo romanzo.", "correctAnswerEnglish": "The latest novel.", "feedback": {"correctItalian": "Bene! Si riferisce alle novità.", "incorrectItalian": "No, è l'ultimo uscito.", "correctEnglish": "Good! It refers to the new releases.", "incorrectEnglish": "No, it's the latest one."}},
  {"id": "s48-p3", "choicesItalian": ["Nel reparto novità.", "In vetrina.", "Sullo scaffale.", "Sotto il tavolo."], "choicesEnglish": ["In the new arrivals section.", "In the window.", "On the shelf.", "Under the table."], "correctAnswerItalian": "Nel reparto novità.", "correctAnswerEnglish": "In the new arrivals section.", "feedback": {"correctItalian": "Ottimo! Indica la sezione giusta.", "incorrectItalian": "No, è tra le novità.", "correctEnglish": "Great! It indicates the right section.", "incorrectEnglish": "No, it's among the new arrivals."}},
  {"id": "s48-p4", "choicesItalian": ["In fondo a destra.", "Vicino all'entrata.", "Al primo piano.", "Fuori dal negozio."], "choicesEnglish": ["At the back on the right.", "Near the entrance.", "On the first floor.", "Outside the shop."], "correctAnswerItalian": "In fondo a destra.", "correctAnswerEnglish": "At the back on the right.", "feedback": {"correctItalian": "Bene! Una direzione comune.", "incorrectItalian": "No, è in fondo.", "correctEnglish": "Good! A common direction.", "incorrectEnglish": "No, it's at the back."}},
  {"id": "s48-p5", "choicesItalian": ["L'edizione economica.", "Il libro costoso.", "La versione rara.", "L'edizione limitata."], "choicesEnglish": ["The paperback edition.", "The expensive book.", "The rare version.", "The limited edition."], "correctAnswerItalian": "L'edizione economica.", "correctAnswerEnglish": "The paperback edition.", "feedback": {"correctItalian": "Esatto! Quella che costa meno.", "incorrectItalian": "No, è quella economica.", "correctEnglish": "Exactly! The cheaper one.", "incorrectEnglish": "No, it's the paperback."}},
  {"id": "s48-p6", "choicesItalian": ["La copertina rigida.", "La carta sottile.", "Il dorso rotto.", "Le pagine bianche."], "choicesEnglish": ["The hardcover.", "The thin paper.", "The broken spine.", "The blank pages."], "correctAnswerItalian": "La copertina rigida.", "correctAnswerEnglish": "The hardcover.", "feedback": {"correctItalian": "Giusto! L'edizione più pregiata.", "incorrectItalian": "No, è la copertina rigida.", "correctEnglish": "Right! The more valuable edition.", "incorrectEnglish": "No, it's the hardcover."}},
  {"id": "s48-p7", "choicesItalian": ["Un pacchetto regalo.", "Una busta nera.", "Una scatola grande.", "Un nastro rosso."], "choicesEnglish": ["A gift wrap.", "A black bag.", "A large box.", "A red ribbon."], "correctAnswerItalian": "Un pacchetto regalo.", "correctAnswerEnglish": "A gift wrap.", "feedback": {"correctItalian": "Molto bene! Per fare un dono.", "incorrectItalian": "No, è un pacchetto regalo.", "correctEnglish": "Very well! To make a gift.", "incorrectEnglish": "No, it's a gift wrap."}},
  {"id": "s48-p8", "choicesItalian": ["Cosa mi consiglia?", "Dove sono?", "Quanto costa?", "Chi è lei?"], "choicesEnglish": ["What do you recommend?", "Where are they?", "How much is it?", "Who are you?"], "correctAnswerItalian": "Cosa mi consiglia?", "correctAnswerEnglish": "What do you recommend?", "feedback": {"correctItalian": "Ottimo! Per chiedere un parere.", "incorrectItalian": "No, chiede un consiglio.", "correctEnglish": "Great! To ask for an opinion.", "incorrectEnglish": "No, he's asking for a recommendation."}},
  {"id": "s48-p9", "choicesItalian": ["Un genere poliziesco.", "Un libro di cucina.", "Una storia d'amore.", "Un racconto horror."], "choicesEnglish": ["A detective genre.", "A cookbook.", "A love story.", "A horror tale."], "correctAnswerItalian": "Un genere poliziesco.", "correctAnswerEnglish": "A detective genre.", "feedback": {"correctItalian": "Bene! Parla di misteri.", "incorrectItalian": "No, è un poliziesco.", "correctEnglish": "Good! It's about mysteries.", "incorrectEnglish": "No, it's a detective genre."}},
  {"id": "s48-p10", "choicesItalian": ["Ambientato in Sicilia.", "Scritto in inglese.", "Letto da molti.", "Venduto ovunque."], "choicesEnglish": ["Set in Sicily.", "Written in English.", "Read by many.", "Sold everywhere."], "correctAnswerItalian": "Ambientato in Sicilia.", "correctAnswerEnglish": "Set in Sicily.", "feedback": {"correctItalian": "Esatto! Indica il luogo.", "incorrectItalian": "No, è l'ambientazione.", "correctEnglish": "Exactly! It indicates the place.", "incorrectEnglish": "No, it's the setting."}},
  {"id": "s48-p11", "choicesItalian": ["Un'altra indagine.", "Una nuova festa.", "Un lungo viaggio.", "Un compito difficile."], "choicesEnglish": ["Another investigation.", "A new party.", "A long trip.", "A difficult task."], "correctAnswerItalian": "Un'altra indagine.", "correctAnswerEnglish": "Another investigation.", "feedback": {"correctItalian": "Giusto! Tipico dei gialli.", "incorrectItalian": "No, è un'indagine.", "correctEnglish": "Right! Typical of mysteries.", "incorrectEnglish": "No, it's an investigation."}},
  {"id": "s48-p12", "choicesItalian": ["È molto avvincente.", "È molto noioso.", "È troppo lungo.", "È molto caro."], "choicesEnglish": ["It's very gripping.", "It's very boring.", "It's too long.", "It's very expensive."], "correctAnswerItalian": "È molto avvincente.", "correctAnswerEnglish": "It's very gripping.", "feedback": {"correctItalian": "Bene! Significa che cattura.", "incorrectItalian": "No, è avvincente.", "correctEnglish": "Good! It means it's captivating.", "incorrectEnglish": "No, it's gripping."}},
  {"id": "s48-p13", "choicesItalian": ["Glielo preparo subito.", "Glielo do domani.", "Non posso farlo.", "Lo faccia lei."], "choicesEnglish": ["I'll prepare it right away.", "I'll give it to you tomorrow.", "I can't do it.", "You do it."], "correctAnswerItalian": "Glielo preparo subito.", "correctAnswerEnglish": "I'll prepare it right away.", "feedback": {"correctItalian": "Esatto! Azione immediata.", "incorrectItalian": "No, lo prepara subito.", "correctEnglish": "Exactly! Immediate action.", "incorrectEnglish": "No, he prepares it right away."}},
  {"id": "s48-p14", "choicesItalian": ["Sempre una garanzia.", "Sempre un problema.", "Mai una gioia.", "Una brutta sorpresa."], "choicesEnglish": ["Always a guarantee.", "Always a problem.", "Never any joy.", "A bad surprise."], "correctAnswerItalian": "Sempre una garanzia.", "correctAnswerEnglish": "Always a guarantee.", "feedback": {"correctItalian": "Giusto! Significa che è affidabile.", "incorrectItalian": "No, è una garanzia.", "correctEnglish": "Right! It means it's reliable.", "incorrectEnglish": "No, it's a guarantee."}},
  {"id": "s48-p15", "choicesItalian": ["Proprio lì in fondo.", "Proprio qui davanti.", "Molto lontano.", "Sopra di noi."], "choicesEnglish": ["Right there at the back.", "Right here in front.", "Very far.", "Above us."], "correctAnswerItalian": "Proprio lì in fondo.", "correctAnswerEnglish": "Right there at the back.", "feedback": {"correctItalian": "Bene! Indica una posizione.", "incorrectItalian": "No, è in fondo.", "correctEnglish": "Good! It indicates a position.", "incorrectEnglish": "No, it's at the back."}},
  {"id": "s48-p16", "choicesItalian": ["È già uscita?", "È ancora aperta?", "È già finita?", "È mai esistita?"], "choicesEnglish": ["Is it out yet?", "Is it still open?", "Is it finished yet?", "Has it ever existed?"], "correctAnswerItalian": "È già uscita?", "correctAnswerEnglish": "Is it out yet?", "feedback": {"correctItalian": "Esatto! Si riferisce a una pubblicazione.", "incorrectItalian": "No, chiede se è uscita.", "correctEnglish": "Exactly! It refers to a publication.", "incorrectEnglish": "No, he's asking if it's out."}},
  {"id": "s48-p17", "choicesItalian": ["Grazie mille.", "Prego tanto.", "Di nulla.", "Scusi ancora."], "choicesEnglish": ["Thanks a lot.", "You're welcome.", "Not at all.", "Sorry again."], "correctAnswerItalian": "Grazie mille.", "correctAnswerEnglish": "Thanks a lot.", "feedback": {"correctItalian": "Bene! Un ringraziamento caloroso.", "incorrectItalian": "No, ringrazia.", "correctEnglish": "Good! A warm thank you.", "incorrectEnglish": "No, he's thanking."}},
  {"id": "s48-p18", "choicesItalian": ["Lo prendo comunque.", "Lo lascio qui.", "Non lo voglio.", "Lo compro dopo."], "choicesEnglish": ["I'll take it anyway.", "I'll leave it here.", "I don't want it.", "I'll buy it later."], "correctAnswerItalian": "Lo prendo comunque.", "correctAnswerEnglish": "I'll take it anyway.", "feedback": {"correctItalian": "Esatto! Accetta nonostante tutto.", "incorrectItalian": "No, lo prende.", "correctEnglish": "Exactly! He accepts despite everything.", "incorrectEnglish": "No, he's taking it."}},
  {"id": "s48-p19", "choicesItalian": ["Un regalo per un amico.", "Un libro per me.", "Un saggio per scuola.", "Un fumetto per bambini."], "choicesEnglish": ["A gift for a friend.", "A book for me.", "An essay for school.", "A comic for children."], "correctAnswerItalian": "Un regalo per un amico.", "correctAnswerEnglish": "A gift for a friend.", "feedback": {"correctItalian": "Giusto! Spiega lo scopo.", "incorrectItalian": "No, è per un amico.", "correctEnglish": "Right! It explains the purpose.", "incorrectEnglish": "No, it's for a friend."}},
  {"id": "s48-p20", "choicesItalian": ["Autore scandinavo.", "Scrittore italiano.", "Poeta francese.", "Regista inglese."], "choicesEnglish": ["Scandinavian author.", "Italian writer.", "French poet.", "English director."], "correctAnswerItalian": "Autore scandinavo.", "correctAnswerEnglish": "Scandinavian author.", "feedback": {"correctItalian": "Bene! Indica la provenienza.", "incorrectItalian": "No, è scandinavo.", "correctEnglish": "Good! It indicates the origin.", "incorrectEnglish": "No, it's Scandinavian."}},
  {"id": "s48-p21", "choicesItalian": ["Va molto forte.", "È molto lento.", "È poco conosciuto.", "Non vende nulla."], "choicesEnglish": ["It's doing very well.", "It's very slow.", "It's little known.", "It sells nothing."], "correctAnswerItalian": "Va molto forte.", "correctAnswerEnglish": "It's doing very well.", "feedback": {"correctItalian": "Esatto! Significa che ha successo.", "incorrectItalian": "No, ha successo.", "correctEnglish": "Exactly! It means it's successful.", "incorrectEnglish": "No, it's successful."}},
  {"id": "s48-p22", "choicesItalian": ["Un classico moderno.", "Un libro antico.", "Una storia recente.", "Un saggio futuro."], "choicesEnglish": ["A modern classic.", "An ancient book.", "A recent story.", "A future essay."], "correctAnswerItalian": "Un classico moderno.", "correctAnswerEnglish": "A modern classic.", "feedback": {"correctItalian": "Giusto! Un'opera recente ma importante.", "incorrectItalian": "No, è un classico moderno.", "correctEnglish": "Right! A recent but important work.", "incorrectEnglish": "No, it's a modern classic."}},
  {"id": "s48-p23", "choicesItalian": ["Trama avvincente.", "Storia noiosa.", "Libro corto.", "Copertina brutta."], "choicesEnglish": ["Gripping plot.", "Boring story.", "Short book.", "Ugly cover."], "correctAnswerItalian": "Trama avvincente.", "correctAnswerEnglish": "Gripping plot.", "feedback": {"correctItalian": "Bene! Descrive bene un giallo.", "incorrectItalian": "No, è avvincente.", "correctEnglish": "Good! It describes a mystery well.", "incorrectEnglish": "No, it's gripping."}},
  {"id": "s48-p24", "choicesItalian": ["Tra qualche mese.", "Tra pochi giorni.", "L'anno prossimo.", "Mai più."], "choicesEnglish": ["In a few months.", "In a few days.", "Next year.", "Never again."], "correctAnswerItalian": "Tra qualche mese.", "correctAnswerEnglish": "In a few months.", "feedback": {"correctItalian": "Esatto! Indica un tempo futuro.", "incorrectItalian": "No, tra mesi.", "correctEnglish": "Exactly! It indicates a future time.", "incorrectEnglish": "No, in months."}},
  {"id": "s48-p25", "choicesItalian": ["Solo quella rilegata.", "Solo quella usata.", "Solo la digitale.", "Tutte le versioni."], "choicesEnglish": ["Only the bound one.", "Only the used one.", "Only the digital one.", "All versions."], "correctAnswerItalian": "Solo quella rilegata.", "correctAnswerEnglish": "Only the bound one.", "feedback": {"correctItalian": "Giusto! Si parla della rilegatura.", "incorrectItalian": "No, è rilegata.", "correctEnglish": "Right! It's about the binding.", "incorrectEnglish": "No, it's bound."}},
  {"id": "s48-p26", "choicesItalian": ["Posso sfogliare?", "Posso comprare?", "Posso leggere?", "Posso andare?"], "choicesEnglish": ["Can I leaf through?", "Can I buy?", "Can I read?", "Can I go?"], "correctAnswerItalian": "Posso sfogliare?", "correctAnswerEnglish": "Can I leaf through?", "feedback": {"correctItalian": "Bene! Per guardare il libro.", "incorrectItalian": "No, vuole sfogliare.", "correctEnglish": "Good! To look at the book.", "incorrectEnglish": "No, he wants to leaf through."}},
  {"id": "s48-p27", "choicesItalian": ["Dov'è la cassa?", "Dov'è il bagno?", "Dov'è l'uscita?", "Dov'è il pane?"], "choicesEnglish": ["Where is the checkout?", "Where is the bathroom?", "Where is the exit.", "Where is the bread?"], "correctAnswerItalian": "Dov'è la cassa?", "correctAnswerEnglish": "Where is the checkout?", "feedback": {"correctItalian": "Esatto! Per pagare.", "incorrectItalian": "No, cerca la cassa.", "correctEnglish": "Exactly! To pay.", "incorrectEnglish": "No, he's looking for the checkout."}},
  {"id": "s48-p28", "choicesItalian": ["Prendo questo.", "Lascio questo.", "Voglio quello.", "Guardo solo."], "choicesEnglish": ["I'll take this one.", "I'll leave this one.", "I want that one.", "I'm just looking."], "correctAnswerItalian": "Prendo questo.", "correctAnswerEnglish": "I'll take this one.", "feedback": {"correctItalian": "Giusto! Per confermare l'acquisto.", "incorrectItalian": "No, lo prende.", "correctEnglish": "Right! To confirm the purchase.", "incorrectEnglish": "No, he's taking it."}},
  {"id": "s48-p29", "choicesItalian": ["È disponibile?", "È finito?", "È aperto?", "È caro?"], "choicesEnglish": ["Is it available?", "Is it finished?", "Is it open?", "Is it expensive?"], "correctAnswerItalian": "È disponibile?", "correctAnswerEnglish": "Is it available?", "feedback": {"correctItalian": "Bene! Per sapere se c'è.", "incorrectItalian": "No, chiede la disponibilità.", "correctEnglish": "Good! To know if it's there.", "incorrectEnglish": "No, he's asking for availability."}},
  {"id": "s48-p30", "choicesItalian": ["Potrebbe ordinarlo?", "Potrebbe leggerlo?", "Potrebbe venderlo?", "Potrebbe darmelo?"], "choicesEnglish": ["Could you order it?", "Could you read it?", "Could you sell it?", "Could you give it to me?"], "correctAnswerItalian": "Potrebbe ordinarlo?", "correctAnswerEnglish": "Could you order it?", "feedback": {"correctItalian": "Esatto! Se il libro manca.", "incorrectItalian": "No, vuole ordinarlo.", "correctEnglish": "Exactly! If the book is missing.", "incorrectEnglish": "No, he wants to order it."}},
  {"id": "s48-p31", "choicesItalian": ["Quanto tempo ci vuole?", "Quanto costa?", "Chi lo ha scritto?", "Dove siamo?"], "choicesEnglish": ["How long does it take?", "How much is it?", "Who wrote it?", "Where are we?"], "correctAnswerItalian": "Quanto tempo ci vuole?", "correctAnswerEnglish": "How long does it take?", "feedback": {"correctItalian": "Giusto! Per sapere l'attesa.", "incorrectItalian": "No, chiede il tempo.", "correctEnglish": "Right! To know the wait.", "incorrectEnglish": "No, he's asking about the time."}},
  {"id": "s48-p32", "choicesItalian": ["Le serve altro?", "Le piace questo?", "Lo vuole ora?", "Cosa fa?"], "choicesEnglish": ["Do you need anything else?", "Do you like this?", "Do you want it now?", "What are you doing?"], "correctAnswerItalian": "Le serve altro?", "correctAnswerEnglish": "Do you need anything else?", "feedback": {"correctItalian": "Bene! Una domanda del commesso.", "incorrectItalian": "No, chiede se serve altro.", "correctEnglish": "Good! A clerk's question.", "incorrectEnglish": "No, he's asking if anything else is needed."}},
  {"id": "s48-p33", "choicesItalian": ["No, grazie.", "Sì, per favore.", "Forse dopo.", "Non saprei."], "choicesEnglish": ["No, thank you.", "Yes, please.", "Maybe later.", "I wouldn't know."], "correctAnswerItalian": "No, grazie.", "correctAnswerEnglish": "No, thank you.", "feedback": {"correctItalian": "Esatto! Una risposta gentile.", "incorrectItalian": "No, declina.", "correctEnglish": "Exactly! A polite response.", "incorrectEnglish": "No, he's declining."}},
  {"id": "s48-p34", "choicesItalian": ["Un segnalibro in omaggio.", "Un libro gratis.", "Una borsa di plastica.", "Una penna rotta."], "choicesEnglish": ["A free bookmark.", "A free book.", "A plastic bag.", "A broken pen."], "correctAnswerItalian": "Un segnalibro in omaggio.", "correctAnswerEnglish": "A free bookmark.", "feedback": {"correctItalian": "Giusto! Un piccolo regalo.", "incorrectItalian": "No, è un segnalibro.", "correctEnglish": "Right! A small gift.", "incorrectEnglish": "No, it's a bookmark."}},
  {"id": "s48-p35", "choicesItalian": ["Posso pagare con carta?", "Posso pagare domani?", "Accettate sassi?", "È gratis?"], "choicesEnglish": ["Can I pay by card?", "Can I pay tomorrow?", "Do you accept stones?", "Is it free?"], "correctAnswerItalian": "Posso pagare con carta?", "correctAnswerEnglish": "Can I pay by card?", "feedback": {"correctItalian": "Bene! Metodo di pagamento.", "incorrectItalian": "No, chiede della carta.", "correctEnglish": "Good! Method of payment.", "incorrectEnglish": "No, he's asking about the card."}},
  {"id": "s48-p36", "choicesItalian": ["Ecco lo scontrino.", "Ecco il libro.", "Ecco il resto.", "Ecco la porta."], "choicesEnglish": ["Here is the receipt.", "Here is the book.", "Here is the change.", "Here is the door."], "correctAnswerItalian": "Ecco lo scontrino.", "correctAnswerEnglish": "Here is the receipt.", "feedback": {"correctItalian": "Esatto! A fine acquisto.", "incorrectItalian": "No, è lo scontrino.", "correctEnglish": "Exactly! At the end of the purchase.", "incorrectEnglish": "No, it's the receipt."}},
  {"id": "s48-p37", "choicesItalian": ["Buona lettura!", "Buon viaggio!", "Buon appetito!", "Buon lavoro!"], "choicesEnglish": ["Enjoy your reading!", "Have a good trip!", "Enjoy your meal!", "Have a good job!"], "correctAnswerItalian": "Buona lettura!", "correctAnswerEnglish": "Enjoy your reading!", "feedback": {"correctItalian": "Ottimo! Augurio in libreria.", "incorrectItalian": "No, augura buona lettura.", "correctEnglish": "Great! A wish in a bookstore.", "incorrectEnglish": "No, he's wishing happy reading."}},
  {"id": "s48-p38", "choicesItalian": ["C'è uno sconto?", "È troppo caro?", "Posso averlo?", "Chi lo vuole?"], "choicesEnglish": ["Is there a discount?", "Is it too expensive?", "Can I have it?", "Who wants it?"], "correctAnswerItalian": "C'è uno sconto?", "correctAnswerEnglish": "Is there a discount?", "feedback": {"correctItalian": "Bene! Per risparmiare.", "incorrectItalian": "No, chiede lo sconto.", "correctEnglish": "Good! To save money.", "incorrectEnglish": "No, he's asking for a discount."}},
  {"id": "s48-p39", "choicesItalian": ["Un libro illustrato.", "Un libro scritto male.", "Una foto brutta.", "Un quadro caro."], "choicesEnglish": ["An illustrated book.", "A poorly written book.", "A bad photo.", "An expensive painting."], "correctAnswerItalian": "Un libro illustrato.", "correctAnswerEnglish": "An illustrated book.", "feedback": {"correctItalian": "Esatto! Con figure.", "incorrectItalian": "No, è illustrato.", "correctEnglish": "Exactly! With pictures.", "incorrectEnglish": "No, it's illustrated."}},
  {"id": "s48-p40", "choicesItalian": ["Letteratura contemporanea.", "Storia antica.", "Grammatica difficile.", "Fiabe vecchie."], "choicesEnglish": ["Contemporary literature.", "Ancient history.", "Difficult grammar.", "Old fairy tales."], "correctAnswerItalian": "Letteratura contemporanea.", "correctAnswerEnglish": "Contemporary literature.", "feedback": {"correctItalian": "Giusto! Autori di oggi.", "incorrectItalian": "No, è contemporanea.", "correctEnglish": "Right! Authors of today.", "incorrectEnglish": "No, it's contemporary."}},
  {"id": "s48-p41", "choicesItalian": ["Una guida della città.", "Una mappa del tesoro.", "Un biglietto del bus.", "Un gelato."] , "choicesEnglish": ["A city guide.", "A treasure map.", "A bus ticket.", "An ice cream."], "correctAnswerItalian": "Una guida della città.", "correctAnswerEnglish": "A city guide.", "feedback": {"correctItalian": "Bene! Utile per i turisti.", "incorrectItalian": "No, è una guida.", "correctEnglish": "Good! Useful for tourists.", "incorrectEnglish": "No, it's a guide."}},
  {"id": "s48-p42", "choicesItalian": ["Dov'è il reparto ragazzi?", "Dov'è il bagno?", "Dov'è il mare?", "Dov'è il gatto?"], "choicesEnglish": ["Where is the children's section?", "Where is the bathroom?", "Where is the sea?", "Where is the cat?"], "correctAnswerItalian": "Dov'è il reparto ragazzi?", "correctAnswerEnglish": "Where is the children's section?", "feedback": {"correctItalian": "Esatto! Per i più piccoli.", "incorrectItalian": "No, cerca il reparto ragazzi.", "correctEnglish": "Exactly! For the little ones.", "incorrectEnglish": "No, he's looking for the children's section."}},
  {"id": "s48-p43", "choicesItalian": ["C'è in magazzino?", "È sul tavolo?", "È fuori?", "È rotto?"], "choicesEnglish": ["Is it in stock?", "Is it on the table?", "Is it outside?", "Is it broken?"], "correctAnswerItalian": "C'è in magazzino?", "correctAnswerEnglish": "Is it in stock?", "feedback": {"correctItalian": "Giusto! Per verificare le scorte.", "incorrectItalian": "No, chiede del magazzino.", "correctEnglish": "Right! To check stock.", "incorrectEnglish": "No, he's asking about the stock."}},
