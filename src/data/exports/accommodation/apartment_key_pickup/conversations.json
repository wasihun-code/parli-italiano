            {
              "text": "Prendo un ascensore ora.",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/8cd83b48e40f.opus"
              }
            },
            {
              "text": "Il vicolo è chiuso ora.",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/6621fb826191.opus"
              }
            }
          ],
          "audio": {
            "italian": "/audio/adfe7ac61b4d.opus"
          }
        },
        {
          "id": "m5",
          "role": "host",
          "text": "Sì, entra. Vedi un cortile?",
