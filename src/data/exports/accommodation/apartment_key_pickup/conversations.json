            {
              "text": "Sì, sono davanti al palazzo.",
              "isCorrect": true,
              "audio": {
                "italian": "/audio/881a628cac67.opus"
              }
            },
            {
              "text": "No, sono dentro il palazzo.",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/5af55db54148.opus"
              }
            },
            {
              "text": "Sì, sono dentro la stanza.",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/dd0d953e6658.opus"
              }
            }
          ],
          "audio": {
            "italian": "/audio/36d672845c5e.opus"
          }
        },
        {
          "id": "m2",
          "role": "host",
          "text": "Ottimo. Il portone è chiuso?",
          "english": "Excellent. Is the building door closed?",
