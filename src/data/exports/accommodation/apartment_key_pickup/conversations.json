              "audio": {
                "italian": "/audio/948e6d267de6.opus"
              }
            },
            {
              "text": "Sono in ascensore.",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/adf16b4d0f95.opus"
              }
            },
            {
              "text": "Vedo il terzo piano.",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/d33dd35f032d.opus"
              }
            }
          ],
          "audio": {
            "italian": "/audio/768da7f8e13b.opus"
          }
        },
        {
          "id": "m2",
          "role": "host",
          "text": "Vedi il numero civico?",
