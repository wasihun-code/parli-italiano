            }
          ],
          "audio": {
            "italian": "/audio/04671ade2144.opus"
          }
        },
        {
          "id": "m7",
          "role": "host",
          "text": "Digita il codice segreto.",
          "english": "Type the secret code.",
          "choices": [
            {
              "text": "Fatto. Il cancello si apre.",
              "isCorrect": true,
              "audio": {
                "italian": "/audio/d4362da35032.opus"
              }
            },
            {
              "text": "Non ho le chiavi oggi.",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/cfedcbe10080.opus"
              }
            },
            {
              "text": "Il codice è sbagliato.",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/d4a667288806.opus"
              }
            }
          ],
          "audio": {
            "italian": "/audio/dc9b0991525c.opus"
          }
        },
