            },
            {
              "text": "Il cortile è al quinto.",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/82639388a504.opus"
              }
            }
          ],
          "audio": {
            "italian": "/audio/50dba710cc8f.opus"
          }
        },
        {
          "id": "m6",
          "role": "host",
          "text": "Quello è l'ingresso. C'è un tastierino.",
          "english": "That is the entrance. There is a keypad.",
