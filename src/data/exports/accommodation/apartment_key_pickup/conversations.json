            {
              "text": "Sì, il portone è chiuso.",
              "isCorrect": true,
              "audio": {
                "italian": "/audio/5dbb649351b6.opus"
              }
            },
            {
              "text": "No, la finestra è aperta.",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/855e06051f62.opus"
              }
            },
            {
              "text": "Sì, la cassetta è grande.",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/ece6a36efdc1.opus"
              }
            }
          ],
          "audio": {
            "italian": "/audio/323c3efe82a3.opus"
          }
        },
        {
          "id": "m3",
          "role": "host",
          "text": "Hai il codice per entrare?",
          "english": "Do you have the code to enter?",
          "choices": [
            {
              "text": "No, non ho il codice.",
              "isCorrect": true,
              "audio": {
                "italian": "/audio/a51b4e2da652.opus"
              }
            },
            {
              "text": "Sì, ho una chiave rotta.",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/655bed23e16d.opus"
              }
            },
            {
              "text": "No, non ho la cassetta.",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/cd8af5aca273.opus"
              }
            }
          ],
          "audio": {
            "italian": "/audio/1310d58125da.opus"
          }
        },
        {
          "id": "m4",
          "role": "host",
          "text": "Digita il codice. Poi premi il tasto.",
          "english": "Type the code. Then press the button.",
          "choices": [
            {
              "text": "Ok, digito il codice ora.",
              "isCorrect": true,
              "audio": {
                "italian": "/audio/b02059ad4fa9.opus"
              }
            },
            {
              "text": "No, chiudo il portone.",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/99e5167cd8f5.opus"
              }
            },
            {
              "text": "Sì, suono il citofono.",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/b6d7076d25f9.opus"
              }
            }
          ],
          "audio": {
            "italian": "/audio/e4740e747623.opus"
          }
        },
        {
          "id": "m5",
          "role": "host",
          "text": "Ha funzionato? Sei dentro?",
          "english": "Did it work? Are you inside?",
          "choices": [
            {
              "text": "Sì, ha funzionato. Sono dentro.",
              "isCorrect": true,
              "audio": {
                "italian": "/audio/e8db206bb52c.opus"
              }
            },
            {
              "text": "No, non sono arrivato.",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/709f34a41f45.opus"
              }
            },
            {
              "text": "Sì, il portone è bloccato.",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/bfde9c83962d.opus"
              }
            }
          ],
          "audio": {
            "italian": "/audio/3e5eaf032e69.opus"
          }
        },
        {
          "id": "m6",
          "role": "host",
          "text": "Bene. Prendi l'ascensore.",
          "english": "Good. Take the elevator.",
          "choices": [
            {
              "text": "Dov'è l'ascensore?",
              "isCorrect": true,
              "audio": {
                "italian": "/audio/936e76229172.opus"
              }
            },
            {
              "text": "Dov'è il citofono?",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/4a4dff5c3a03.opus"
              }
            },
            {
              "text": "Qual è il codice?",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/0df507fca2d0.opus"
              }
            }
          ],
          "audio": {
            "italian": "/audio/a321cbb05b1c.opus"
          }
        },
        {
          "id": "m7",
          "role": "host",
          "text": "È in fondo. Sali al terzo piano.",
          "english": "It is at the end. Go up to the third floor.",
          "choices": [
            {
              "text": "Vado al terzo piano.",
              "isCorrect": true,
              "audio": {
                "italian": "/audio/5131ec14e292.opus"
              }
            },
            {
              "text": "Vado al secondo piano.",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/0a3221ed1d2f.opus"
              }
            },
            {
              "text": "Esco dal palazzo ora.",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/1530233b5e19.opus"
              }
            }
          ],
          "audio": {
            "italian": "/audio/e5e603aacac6.opus"
          }
        },
        {
          "id": "m8",
          "role": "host",
          "text": "Cerca la porta. C'è una cassetta.",
          "english": "Look for the door. There is a box.",
          "choices": [
            {
              "text": "Vedo la cassetta sicura.",
              "isCorrect": true,
              "audio": {
                "italian": "/audio/2eac6e324a8b.opus"
              }
            },
            {
              "text": "La porta è aperta ora.",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/4ea6ff4b6e81.opus"
              }
            },
            {
              "text": "Suono il citofono ora.",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/8af36477fe23.opus"
              }
            }
          ],
          "audio": {
            "italian": "/audio/d021d54bffee.opus"
          }
        },
        {
          "id": "m9",
          "role": "host",
          "text": "Usa il codice della cassetta.",
          "english": "Use the code for the box.",
          "choices": [
            {
              "text": "Metto il codice subito.",
              "isCorrect": true,
              "audio": {
                "italian": "/audio/0058b690b04d.opus"
              }
            },
            {
              "text": "Giro la maniglia ora.",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/1f6ea7f377f5.opus"
              }
            },
            {
              "text": "Cerco la porta rotta.",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/e53e99f83a77.opus"
              }
            }
          ],
          "audio": {
            "italian": "/audio/372a7b18f905.opus"
          }
        },
        {
          "id": "m10",
          "role": "host",
          "text": "Prendi le chiavi e apri la porta.",
          "english": "Take the keys and open the door.",
          "choices": [
            {
              "text": "Ho le chiavi. Apro la porta.",
              "isCorrect": true,
              "audio": {
                "italian": "/audio/22f804d3a9a7.opus"
              }
            },
            {
              "text": "Lascio le chiavi per te.",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/8948077256a1.opus"
              }
            },
            {
              "text": "La porta è bloccata ora.",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/bb4ede7e8ebe.opus"
              }
            }
          ],
          "audio": {
            "italian": "/audio/00816597523c.opus"
          }
        },
        {
          "id": "m11",
          "role": "host",
          "text": "Benvenuto! Trovi le regole sul tavolo.",
          "english": "Welcome! You find the rules on the table.",
          "choices": [
            {
              "text": "Grazie mille. A presto!",
              "isCorrect": true,
              "nextMessageId": "END",
              "audio": {
                "italian": "/audio/ef87eb4b8b23.opus"
              }
            },
            {
              "text": "Dove sono le scale?",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/81455de2fc15.opus"
              }
            },
            {
              "text": "Ho perso le chiavi.",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/7788edd913d0.opus"
              }
            }
          ],
          "audio": {
            "italian": "/audio/900c2dfb7f0f.opus"
          }
        }
      ]
    },
    {
      "id": "cant_find_building",
      "title": "Can't Find the Building",
      "description": "Navigate a confusing street.",
      "messages": [
        {
          "id": "m1",
          "role": "host",
          "text": "Pronto? Dove sei?",
          "english": "Hello? Where are you?",
