              "audio": {
                "italian": "/audio/80d3bfe1a7e2.opus"
              }
            },
            {
              "text": "No, sono dentro ora.",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/1b002a5ebba0.opus"
              }
            },
            {
              "text": "Qual è il codice?",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/0df507fca2d0.opus"
              }
            }
          ],
          "audio": {
            "italian": "/audio/8f2038f41d17.opus"
