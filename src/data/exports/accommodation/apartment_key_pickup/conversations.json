            {
              "text": "Prendo le scale ora.",
              "isCorrect": true,
              "audio": {
                "italian": "/audio/894110600aa6.opus"
              }
            },
            {
              "text": "Vado al primo piano.",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/a88dbe414b25.opus"
              }
            },
            {
              "text": "Il cortile è scuro.",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/bb571238206e.opus"
              }
            }
          ],
          "audio": {
            "italian": "/audio/93c6f1267d5a.opus"
          }
        },
        {
          "id": "m9",
          "role": "host",
          "text": "La porta è nascosta. Ti aspetto.",
          "english": "The door is hidden. I am waiting.",
          "choices": [
            {
              "text": "Arrivo subito da te.",
              "isCorrect": true,
              "audio": {
                "italian": "/audio/19edf9d20752.opus"
              }
            },
            {
              "text": "Sono molto in ritardo.",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/a84f10a68ce8.opus"
              }
            },
            {
              "text": "Dov'è il citofono oggi?",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/f4ae9deffe4e.opus"
              }
            }
          ],
          "audio": {
            "italian": "/audio/e463a4a34747.opus"
          }
        },
        {
          "id": "m10",
          "role": "host",
          "text": "Eccoti! Finalmente sei arrivato.",
          "english": "There you are! Finally you arrived.",
          "choices": [
            {
              "text": "Grazie dell'aiuto. A presto!",
              "isCorrect": true,
              "nextMessageId": "END",
              "audio": {
                "italian": "/audio/88db9239babe.opus"
              }
            },
            {
              "text": "Voglio uscire da qui.",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/5ae41940d72d.opus"
              }
            },
            {
              "text": "Il portone è chiuso.",
              "isCorrect": false,
              "audio": {
                "italian": "/audio/391dc54ea40a.opus"
              }
            }
          ],
          "audio": {
            "italian": "/audio/7722cf92b3e7.opus"
          }
        }
      ]
