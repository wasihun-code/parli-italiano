{
  "scenarioId": 22,
  "conversations": [
    {
      "id": "smooth_check_in",
      "title": "Smooth Check-In",
      "description": "Meet your host and enter the building normally.",
      "messages": [
        {
          "id": "m1",
          "role": "host",
          "text": "Ciao! Sei davanti al palazzo?",
          "english": "Hi! Are you in front of the building?",
